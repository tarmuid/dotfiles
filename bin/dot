#!/usr/bin/env sh

set -eu

DOT_ROOT="$(cd "$(dirname "$0")/.." && pwd)"
MODULES_DIR="$DOT_ROOT/modules"
PROFILES_FILE="$DOT_ROOT/profiles.yml"
DEFAULT_XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-"$HOME/.config"}"
DEFAULT_XDG_STATE_HOME="${XDG_STATE_HOME:-"$HOME/.local/state"}"
BREW_CONFIG_DIR="$DEFAULT_XDG_CONFIG_HOME/brew"
BREW_MODULES_DIR="$BREW_CONFIG_DIR/modules"
BREWFILE_PATH="$BREW_CONFIG_DIR/Brewfile"
DOT_STATE_DIR="$DEFAULT_XDG_STATE_HOME/dot"
ACTIVE_MODULES_FILE="$DOT_STATE_DIR/active-modules"
BREWFILE_UPDATE_NEEDED=0
FORCE=0

log() {
  printf "dot: %s\n" "$*" >&2
}

fail() {
  log "$*"
  exit 1
}

usage() {
  cat <<'EOF'
dot - minimal module manager for these dotfiles

Usage:
  dot apply [--force] [--profile <name>] [module ...]
  dot disable [--profile <name>] [module ...]
  dot list active|inactive
  dot help

apply      Enable modules (runs module apply script or links files). --force replaces existing files.
disable    Disable modules (runs module disable script or unlinks files).
list       Show tracked active modules, or inactive modules from the modules directory.

If no modules are provided to apply/disable, the default profile from profiles.yml is used.
EOF
}

profile_modules() {
  profile="$1"

  [ -f "$PROFILES_FILE" ] || fail "profiles file not found: $PROFILES_FILE"

  modules=$(
    awk -v profile="$profile" '
      BEGIN { in_target=0; in_modules=0 }
      /^[[:space:]]*#/ { next }
      /^profiles:/ { in_profiles=1; next }
      in_profiles && $0 ~ /^  [^[:space:]]/ {
        line=$0
        sub(/^  /,"",line)
        sub(/:.*/,"",line)
        current=line
        in_target = (current == profile)
        in_modules = 0
        next
      }
      in_target && /^    modules:[[:space:]]*$/ { in_modules=1; next }
      in_target && in_modules && $0 ~ /^[[:space:]]*-/ {
        line=$0
        sub(/^[[:space:]]*-[[:space:]]*/, "", line)
        print line
        next
      }
      in_target && $0 ~ /^  [^[:space:]]/ { exit 0 }
      END { if (in_target == 0) exit 2 }
    ' "$PROFILES_FILE"
  )

  status=$?
  [ $status -eq 0 ] || fail "profile not found: $profile"
  [ -n "$modules" ] || fail "profile '$profile' has no modules"

  printf "%s\n" "$modules"
}

maybe_default_profile() {
  if [ -f "$PROFILES_FILE" ]; then
    if awk '/^profiles:/{found=1} found && /^[[:space:]]{2}default:/{exit 0} END{exit 1}' "$PROFILES_FILE"; then
      profile_modules "default"
      return 0
    fi
  fi
  fail "no modules specified and no default profile found"
}

manifest_path() {
  module_dir="$1"
  if [ -f "$module_dir/_links" ]; then
    printf "%s\n" "$module_dir/_links"
    return 0
  fi
  if [ -f "$module_dir/links" ]; then
    printf "%s\n" "$module_dir/links"
    return 0
  fi
  return 1
}

brew_manifest_path() {
  module_dir="$1"
  if [ -f "$module_dir/_brew" ]; then
    printf "%s\n" "$module_dir/_brew"
    return 0
  fi
  if [ -f "$module_dir/Brewfile" ]; then
    printf "%s\n" "$module_dir/Brewfile"
    return 0
  fi
  return 1
}

link_module_tree() {
  module="$1"
  module_dir="$MODULES_DIR/$module"
  home_dir="$module_dir/home"

  [ -d "$home_dir" ] || {
    log "no \$HOME directory for $module; nothing to link"
    return 0
  }

  log "linking files for $module"

  find "$home_dir" -mindepth 1 \( -type f -o -type l \) | while IFS= read -r src; do
    rel=${src#$home_dir/}
    dest="$HOME/$rel"
    dest_dir=$(dirname "$dest")
    [ -d "$dest_dir" ] || mkdir -p "$dest_dir"

    if [ -L "$dest" ] && [ "$(readlink "$dest")" = "$src" ]; then
      continue
    fi

    if [ -e "$dest" ] && [ ! -L "$dest" ]; then
      if [ "$FORCE" -eq 1 ]; then
        log "replacing existing path with link: $dest"
        rm -rf "$dest"
      else
        log "skip existing path (not a symlink): $dest (use --force to replace)"
        continue
      fi
    fi

    [ -L "$dest" ] && rm "$dest"
    ln -s "$src" "$dest"
  done
}

unlink_module_tree() {
  module="$1"
  module_dir="$MODULES_DIR/$module"
  home_dir="$module_dir/home"

  [ -d "$home_dir" ] || return 0

  log "removing links for $module"

  find "$home_dir" -mindepth 1 \( -type f -o -type l \) | while IFS= read -r src; do
    rel=${src#$home_dir/}
    dest="$HOME/$rel"

    if [ -L "$dest" ] && [ "$(readlink "$dest")" = "$src" ]; then
      rm "$dest"
    fi
  done
}

resolve_dest_path() {
  dest="$1"
  case "$dest" in
    /*) printf "%s\n" "$dest" ;;
    "~"/*) printf "%s\n" "$HOME/${dest#~/}" ;;
    "\$HOME"/*) printf "%s\n" "$HOME/${dest#\$HOME/}" ;;
    "\$XDG_CONFIG_HOME"/*) printf "%s\n" "$DEFAULT_XDG_CONFIG_HOME/${dest#\$XDG_CONFIG_HOME/}" ;;
    *) printf "%s\n" "$HOME/$dest" ;;
  esac
}

manifest_dest_path() {
  src_rel="$1"
  dest_tpl="$2"
  dest=$(resolve_dest_path "$dest_tpl")

  case "$dest_tpl" in
    */)
      dest_no_slash=${dest%/}
      dest_base=$(basename "$dest_no_slash")
      src_base=$(basename "$src_rel")
      if [ "$dest_base" = "$src_base" ]; then
        dest="$dest_no_slash"
      else
        dest="$dest_no_slash/$src_base"
      fi
      ;;
  esac

  printf "%s\n" "$dest"
}

link_manifest() {
  module="$1"
  module_dir="$MODULES_DIR/$module"
  manifest="$(manifest_path "$module_dir")" || return 1

  log "linking files for $module (links manifest)"

  while IFS= read -r line || [ -n "$line" ]; do
    # trim leading/trailing whitespace and skip blanks/comments
    line=$(printf "%s" "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    case "$line" in
      ""|"#"*) continue ;;
    esac

    set -- $line
    [ $# -ge 2 ] || { log "skip malformed line in $manifest: $line"; continue; }

    src_rel="$1"
    dest_tpl="$2"
    src="$module_dir/$src_rel"
    [ -e "$src" ] || { log "source not found in $module: $src_rel"; continue; }

    dest=$(manifest_dest_path "$src_rel" "$dest_tpl")
    dest_dir=$(dirname "$dest")
    [ -d "$dest_dir" ] || mkdir -p "$dest_dir"

    if [ -L "$dest" ] && [ "$(readlink "$dest")" = "$src" ]; then
      continue
    fi

    if [ -e "$dest" ] && [ ! -L "$dest" ]; then
      if [ "$FORCE" -eq 1 ]; then
        log "replacing existing path with link: $dest"
        rm -rf "$dest"
      else
        log "skip existing path (not a symlink): $dest (use --force to replace)"
        continue
      fi
    fi

    [ -L "$dest" ] && rm "$dest"
    ln -s "$src" "$dest"
  done < "$manifest"

  return 0
}

unlink_manifest() {
  module="$1"
  module_dir="$MODULES_DIR/$module"
  manifest="$(manifest_path "$module_dir")" || return 1

  log "removing links for $module (links manifest)"

  while IFS= read -r line || [ -n "$line" ]; do
    line=$(printf "%s" "$line" | sed 's/^[[:space:]]*//;s/[[:space:]]*$//')
    case "$line" in
      ""|"#"*) continue ;;
    esac

    set -- $line
    [ $# -ge 2 ] || continue

    dest_tpl="$2"
    dest=$(manifest_dest_path "$1" "$dest_tpl")

    if [ -L "$dest" ]; then
      rm "$dest"
    fi
  done < "$manifest"

  return 0
}

is_macos() {
  [ "$(uname -s)" = "Darwin" ]
}

brew_module_file() {
  module="$1"
  sanitized=$(printf "%s\n" "$module" | sed 's,/,__,g')
  printf "%s/%s.brew\n" "$BREW_MODULES_DIR" "$sanitized"
}

legacy_brew_module_file() {
  module="$1"
  sanitized=$(printf "%s\n" "$module" | tr '/ ' '__')
  printf "%s/%s.brew\n" "$BREW_MODULES_DIR" "$sanitized"
}

module_name_from_section() {
  section="$1"
  if printf "%s" "$section" | grep -q "__"; then
    printf "%s\n" "$section" | sed 's,__,/,g'
  else
    printf "%s\n" "$section" | sed 's,_,/,g'
  fi
}

record_brew_manifest() {
  module="$1"
  module_dir="$MODULES_DIR/$module"

  is_macos || return 0
  manifest="$(brew_manifest_path "$module_dir")" || return 0

  mkdir -p "$BREW_MODULES_DIR"

  dest="$(brew_module_file "$module")"
  legacy_dest="$(legacy_brew_module_file "$module")"
  {
    printf "# module: %s\n" "$module"
    cat "$manifest"
    printf "\n"
  } > "$dest"
  if [ "$dest" != "$legacy_dest" ] && [ -f "$legacy_dest" ]; then
    rm "$legacy_dest"
  fi

  BREWFILE_UPDATE_NEEDED=1
}

remove_brew_manifest() {
  module="$1"
  dest="$(brew_module_file "$module")"
  legacy_dest="$(legacy_brew_module_file "$module")"

  is_macos || return 0

  if [ -f "$dest" ]; then
    rm "$dest"
    BREWFILE_UPDATE_NEEDED=1
  fi
  if [ "$dest" != "$legacy_dest" ] && [ -f "$legacy_dest" ]; then
    rm "$legacy_dest"
    BREWFILE_UPDATE_NEEDED=1
  fi
}

rebuild_brewfile() {
  is_macos || return 0
  [ "$BREWFILE_UPDATE_NEEDED" -eq 1 ] || return 0

  mkdir -p "$BREW_CONFIG_DIR"

  module_files=$(find "$BREW_MODULES_DIR" -mindepth 1 -maxdepth 1 -type f 2>/dev/null | sort)

  if [ -z "$module_files" ]; then
    [ -f "$BREWFILE_PATH" ] && rm "$BREWFILE_PATH"
    BREWFILE_UPDATE_NEEDED=0
    return 0
  fi

  tmp="$BREWFILE_PATH.tmp"
  {
    printf "# Generated by dot; edit module _brew manifests instead.\n"
    for file in $module_files; do
      printf "\n"
      cat "$file"
    done
  } > "$tmp"

  mv "$tmp" "$BREWFILE_PATH"
  log "updated Brewfile at $BREWFILE_PATH"
  BREWFILE_UPDATE_NEEDED=0
}

ensure_state_dir() {
  [ -d "$DOT_STATE_DIR" ] || mkdir -p "$DOT_STATE_DIR"
}

mark_module_active() {
  module="$1"

  ensure_state_dir
  tmp="$(mktemp "$DOT_STATE_DIR/active-modules.XXXXXX")"
  {
    [ -f "$ACTIVE_MODULES_FILE" ] && cat "$ACTIVE_MODULES_FILE"
    printf "%s\n" "$module"
  } | sort -u > "$tmp"
  mv "$tmp" "$ACTIVE_MODULES_FILE"
}

unmark_module_active() {
  module="$1"

  [ -f "$ACTIVE_MODULES_FILE" ] || return 0

  ensure_state_dir
  tmp="$(mktemp "$DOT_STATE_DIR/active-modules.XXXXXX")"
  grep -Fxv "$module" "$ACTIVE_MODULES_FILE" > "$tmp" || true

  if [ -s "$tmp" ]; then
    mv "$tmp" "$ACTIVE_MODULES_FILE"
  else
    rm -f "$tmp" "$ACTIVE_MODULES_FILE"
  fi
}

list_active_modules() {
  if [ -f "$ACTIVE_MODULES_FILE" ]; then
    cat "$ACTIVE_MODULES_FILE"
  else
    log "no active modules recorded"
  fi
}

list_inactive_modules() {
  active_file="$ACTIVE_MODULES_FILE"
  list_modules | while IFS= read -r module; do
    if [ -f "$active_file" ] && grep -Fxq "$module" "$active_file"; then
      continue
    fi
    printf "%s\n" "$module"
  done
}

run_apply() {
  module="$1"
  module_dir="$MODULES_DIR/$module"

  [ -d "$module_dir" ] || fail "module not found: $module"

  if [ -x "$module_dir/apply" ]; then
    log "applying $module (script)"
    (cd "$module_dir" && DOT_ROOT="$DOT_ROOT" sh ./apply)
  elif ! link_manifest "$module"; then
    link_module_tree "$module"
  fi

  record_brew_manifest "$module"
  mark_module_active "$module"
}

run_disable() {
  module="$1"
  module_dir="$MODULES_DIR/$module"

  [ -d "$module_dir" ] || fail "module not found: $module"

  if [ -x "$module_dir/disable" ]; then
    log "disabling $module (script)"
    (cd "$module_dir" && DOT_ROOT="$DOT_ROOT" sh ./disable)
  elif ! unlink_manifest "$module"; then
    unlink_module_tree "$module"
  fi

  remove_brew_manifest "$module"
  unmark_module_active "$module"
}

list_profiles() {
  [ -f "$PROFILES_FILE" ] || fail "profiles file not found: $PROFILES_FILE"
  awk '
    /^profiles:/ {in_profiles=1; next}
    in_profiles && $0 ~ /^  [^[:space:]]/ {
      line=$0
      sub(/^  /,"",line)
      sub(/:.*/,"",line)
      print line
    }
  ' "$PROFILES_FILE"
}

list_modules() {
  [ -d "$MODULES_DIR" ] || fail "modules directory not found: $MODULES_DIR"
  find "$MODULES_DIR" -mindepth 2 -maxdepth 2 -type d | while IFS= read -r dir; do
    rel=${dir#$MODULES_DIR/}
    printf "%s\n" "$rel"
  done | sort
}

handle_apply_or_disable() {
  action="$1"
  shift

  FORCE=0
  profile=""
  modules=""
  BREWFILE_UPDATE_NEEDED=0

  while [ $# -gt 0 ]; do
    case "$1" in
      --force)
        FORCE=1
        shift
        ;;
      --profile|-p)
        [ $# -ge 2 ] || fail "--profile requires a value"
        profile="$2"
        shift 2
        ;;
      --help|-h)
        usage
        exit 0
        ;;
      --)
        shift
        break
        ;;
      *)
        modules="$modules $1"
        shift
        ;;
    esac
  done

  # shellcheck disable=SC2086
  set -- $modules

  if [ -n "$profile" ]; then
    set -- $(profile_modules "$profile")
  elif [ $# -eq 0 ]; then
    set -- $(maybe_default_profile)
  fi

  [ $# -gt 0 ] || fail "no modules to process"

  for module in "$@"; do
    case "$action" in
      apply) run_apply "$module" ;;
      disable) run_disable "$module" ;;
    esac
  done

  rebuild_brewfile
}

main() {
  command="${1:-help}"
  shift || true

  case "$command" in
    apply) handle_apply_or_disable apply "$@" ;;
    disable) handle_apply_or_disable disable "$@" ;;
    list)
      case "${1:-}" in
        active) list_active_modules ;;
        inactive) list_inactive_modules ;;
        *) usage ;;
      esac
      ;;
    help|-h|--help) usage ;;
    *) fail "unknown command: $command" ;;
  esac
}

main "$@"
