{
  "proxy": "",
  "edit_predictions": {
    "mode": "subtle",
  },
  "agent_servers": {
    "omp": {
      "favorite_config_option_values": {
        "model": ["openai-codex/gpt-5.5"],
        "thinking": ["high"],
        "mode": ["plan"],
      },
      "type": "custom",
      "command": "omp",
      "args": ["acp"],
      "env": {},
    },
  },
  "languages": {
    "Markdown": {
      "formatter": {
        "external": {
          "command": "dprint",
          "arguments": [
            "fmt",
            "--stdin",
            "{buffer_path}",
            "--config-discovery=global",
          ],
        },
      },
      "format_on_save": "on",
      "preferred_line_length": 80,
    },
  },
  "use_system_prompts": false,
  "use_system_path_prompts": false,
  "ui_font_size": 16.0,
  "agent_ui_font_size": 15.0,
  "buffer_font_size": 13.0,
  "theme": "GitHub Dark Dimmed",
  "cli_default_open_behavior": "new_window",
  "git_panel": {
    "file_icons": true,
  },
  "terminal": {
    "show_count_badge": false,
  },
  "project_panel": {
    "git_status_indicator": true,
    "bold_folder_labels": false,
  },
  "buffer_font_family": "Berkeley Mono Variable",
  "telemetry": {
    "metrics": false,
  },
  "vim_mode": true,
}
