moduleName = "harnesses/oh-my-pi"

packages {
  taps = List("can1357/tap")
  brew = List("omp")
}

files = List(
  new Dynamic {
    tree = "home"
    source = "home/.omp/agent/config.yml"
    target = ".omp/agent/config.yml"
  },
  new Dynamic {
    tree = "home"
    source = "home/.omp/agent/AGENTS.md"
    target = ".omp/agent/AGENTS.md"
  },
  new Dynamic {
    tree = "home"
    source = "home/.omp/agent/skills/worktrunk/SKILL.md"
    target = ".omp/agent/skills/worktrunk/SKILL.md"
  }
)
