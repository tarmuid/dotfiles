run_work_bootstrap() {
  bootstrap_script="$repo_root/modules/profiles/work/bootstrap"
  [ -f "$bootstrap_script" ] || return 0

  echo "dot: running work bootstrap script"
  (cd "$repo_root" && sh "$bootstrap_script")
}

AGE_CMD=""
passphrase="${WORK_SECRETS_PASSPHRASE:-}"
# decrypt_work_secrets

decrypt_age_file "$repo_root/modules/profiles/work/_brew.age" "$repo_root/modules/profiles/work/_brew"
decrypt_age_file "$repo_root/modules/profiles/work/bootstrap.age" "$repo_root/modules/profiles/work/bootstrap"

run_work_bootstrap

echo "dot: wrote work git identity to $GIT_LOCAL"
