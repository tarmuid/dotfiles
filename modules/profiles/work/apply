#!/usr/bin/env sh

set -eu

XDG_CONFIG_HOME="${XDG_CONFIG_HOME:-$HOME/.config}"
GIT_LOCAL="$XDG_CONFIG_HOME/git/config.local"

repo_root="${DOT_ROOT:-$(git rev-parse --show-toplevel 2>/dev/null || cd "$(dirname "$0")/../../.." && pwd)}"

name="${DOT_WORK_GIT_NAME:-${GIT_NAME:-}}"
email="${DOT_WORK_GIT_EMAIL:-${GIT_EMAIL:-}}"
signing_key="${DOT_WORK_GIT_SIGNING_KEY:-${GIT_SIGNING_KEY:-}}"

[ -n "$name" ] || { echo "dot: DOT_WORK_GIT_NAME (or GIT_NAME) not set" >&2; exit 1; }
[ -n "$email" ] || { echo "dot: DOT_WORK_GIT_EMAIL (or GIT_EMAIL) not set" >&2; exit 1; }

mkdir -p "$(dirname "$GIT_LOCAL")"

{
  printf "[user]\n"
  printf "name = %s\n" "$name"
  printf "email = %s\n" "$email"
  if [ -n "$signing_key" ]; then
    printf "signingKey = %s\n" "$signing_key"
  fi
} > "$GIT_LOCAL"

age_command() {
  if command -v rage >/dev/null 2>&1; then
    printf "rage"
    return 0
  fi
  if command -v age >/dev/null 2>&1; then
    printf "age"
    return 0
  fi

  echo "dot: install 'rage' (preferred) or 'age' to decrypt work secrets" >&2
  return 1
}

prompt_age_passphrase() {
  [ -n "$passphrase" ] && return 0

  printf "Enter age passphrase: " >&2
  stty -echo 2>/dev/null || true
  IFS= read -r passphrase
  stty echo 2>/dev/null || true
  printf "\n" >&2

  [ -n "$passphrase" ] || {
    echo "dot: empty passphrase; skipping decryption" >&2
    return 1
  }

  export passphrase
}

decrypt_age_file() {
  enc="$1"
  dest="$2"

  [ -f "$enc" ] || return 0
  [ -e "$dest" ] && { echo "dot: decrypted exists; skipping: $dest"; return 0; }

  [ -n "$AGE_CMD" ] || AGE_CMD=$(age_command) || return 0

  prompt_age_passphrase || return 1

  printf "dot: decrypting %s\n" "$(basename "$enc")"

  if ! printf "%s\n" "$passphrase" | "$AGE_CMD" --decrypt --passphrase -o "$dest" "$enc"; then
    echo "dot: failed to decrypt $(basename "$enc")" >&2
    rm -f "$dest"
    return 1
  fi
}

